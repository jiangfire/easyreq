# Database
DATABASE_URL="postgresql://user:password@localhost:5432/easyreq"
# Test database (auto-derived as <DATABASE_URL db>_test by vitest; override here if needed).
# Integration tests refuse to run unless the DSN looks like a test database.
# DATABASE_TEST_URL="postgresql://user:password@localhost:5432/easyreq_test"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# File Storage
# STORAGE_PROVIDER: local | s3
STORAGE_PROVIDER=local
# Local storage directory (when STORAGE_PROVIDER=local).
# IMPORTANT: must NOT live under public/, otherwise Next.js serves files
# directly and bypasses the /api/attachments/:id permission check.
STORAGE_LOCAL_DIR=./uploads
# Max upload size in bytes (default 10MB)
STORAGE_MAX_FILE_SIZE=10485760

# S3 Compatible Storage (when STORAGE_PROVIDER=s3)
# Works with AWS S3, MinIO, Aliyun OSS, etc.
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
# Optional public base URL for S3 objects (if served via CDN)
S3_PUBLIC_URL=
# Set to "true" for MinIO and other path-style endpoints
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AI Plugin (optional, disabled by default)
AI_ENABLED=false
